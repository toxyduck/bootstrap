#!/usr/bin/env bash
set -Eeuo pipefail
REPO=toxyduck/.dotenv
STATE="${XDG_STATE_HOME:-$HOME/.local/state}/toxy"
SSH_FILE="$HOME/.ssh/config.d/toxyduck-machines"
SERVER_URL="${TOXY_SERVER_URL:-https://raw.githubusercontent.com/toxyduck/bootstrap/main/server.sh}"
REMOTE_TERM="${TOXY_REMOTE_TERM:-xterm-256color}"
die(){ echo "toxy: $*" >&2; exit 1; }
help_text(){ cat <<'EOF'
toxy
  toxy machines sync
  toxy machines list
  toxy machines connect <alias>
  toxy setup [alias|user@ip] [--vpn]
  toxy setup --local <alias> [--vpn]
EOF
}
auth(){
  if ! gh auth status -h github.com >/dev/null 2>&1; then
    gh auth login --hostname github.com --web
    gh config set -h github.com git_protocol https 2>/dev/null || gh config set git_protocol https
  fi
  [[ $(gh api user --jq .login) == toxyduck ]] || die 'Use GitHub account toxyduck'
}
rows(){
  local file
  if [[ -n "${TOXY_INVENTORY_FILE:-}" ]]; then file="$TOXY_INVENTORY_FILE"
  else auth; mkdir -p "$STATE"; file="$STATE/machines.toml"; gh api "repos/$REPO/contents/config/machines.toml" --jq .content | python3 -c 'import base64,sys; sys.stdout.buffer.write(base64.b64decode(sys.stdin.buffer.read()))' > "$file"; fi
  python3 - "$file" <<'PY'
import re, sys, tomllib

machines = tomllib.load(open(sys.argv[1], 'rb')).get('machines', [])
seen = set()
for m in machines:
    alias = m.get('alias', '')
    profile = m.get('profile', '')
    has_hostname = bool(m.get('hostname'))
    has_user = bool(m.get('user'))
    if not alias or alias in seen:
        raise SystemExit(f'invalid or duplicate machine alias: {alias!r}')
    if not re.fullmatch(r'[a-z0-9][a-z0-9_-]*', profile):
        raise SystemExit(f'invalid profile for {alias}: {profile!r}')
    if has_hostname != has_user:
        raise SystemExit(f'machine {alias} must define both hostname and user, or neither')
    seen.add(alias)
    values = [
        alias,
        m.get('hostname', '-'),
        m.get('user', '-'),
        str(m.get('port', 22)),
        m.get('proxy_jump', '-'),
        profile,
        '1' if has_hostname else '0',
        '1' if profile == 'yandex' and has_hostname else '0',
    ]
    print('\t'.join(values))
PY
}
machine_row(){ rows | awk -F '\t' -v a="$1" '$1==a {print; exit}'; }
machines_sync(){
  mkdir -p "$HOME/.ssh/config.d"; chmod 700 "$HOME/.ssh"; tmp=$(mktemp)
  { echo '# Managed by toxy'; while IFS=$'\t' read -r a h u p j profile remote forward; do
      [[ "$remote" == 0 ]] && continue
      printf '\nHost %s\n  HostName %s\n  User %s\n  Port %s\n  SetEnv TERM=%s\n' "$a" "$h" "$u" "$p" "$REMOTE_TERM"
      [[ "$j" == - ]] || printf '  ProxyJump %s\n' "$j"
      [[ "$forward" == 0 ]] || printf '  ForwardAgent yes\n'
    done < <(rows); } > "$tmp"
  install -m 600 "$tmp" "$SSH_FILE"; rm -f "$tmp"; touch "$HOME/.ssh/config"; chmod 600 "$HOME/.ssh/config"
  filtered_tmp=$(mktemp); sed "/^Include .*config\.d\/\*$/d" "$HOME/.ssh/config" > "$filtered_tmp"
  main_tmp=$(mktemp); { printf "Include %s/.ssh/config.d/*\n\n" "$HOME"; cat "$filtered_tmp"; } > "$main_tmp"
  install -m 600 "$main_tmp" "$HOME/.ssh/config"; rm -f "$filtered_tmp" "$main_tmp"
  echo 'SSH presets updated'
}
machines_list(){
  while IFS=$'\t' read -r a h u p _ profile remote _; do
    if [[ "$remote" == 0 ]]; then printf '%-20s profile-only  profile=%s\n' "$a" "$profile"
    else printf '%-20s %s@%s:%s  profile=%s\n' "$a" "$u" "$h" "$p" "$profile"; fi
  done < <(rows)
}
connect_machine(){
  local alias="$1" row h u p j profile remote forward
  row=$(machine_row "$alias"); [[ -n "$row" ]] || die "Unknown alias: $alias"
  IFS=$'\t' read -r _ h u p j profile remote forward <<< "$row"
  [[ "$remote" == 1 ]] || die "Machine $alias has no SSH endpoint"
  local -a args=(-p "$p" -o "SetEnv=TERM=$REMOTE_TERM"); [[ "$j" == - ]] || args+=(-J "$j")
  [[ "$forward" == 0 ]] || args+=(-A)
  exec ssh "${args[@]}" "$u@$h"
}
choose(){ machines_list >&2; read -r -p 'Machine alias or user@ip: ' target </dev/tty; [[ -n "$target" ]] || die 'Target required'; echo "$target"; }
run_local_setup(){
  local alias="$1" vpn="$2" row profile remote tmp
  row=$(machine_row "$alias"); [[ -n "$row" ]] || die "Unknown alias: $alias"
  IFS=$'\t' read -r _ _ _ _ _ profile remote _ <<< "$row"
  local result
  tmp=$(mktemp)
  curl -fsSL "$SERVER_URL" -o "$tmp"
  if [[ -n "$vpn" ]]; then
    if bash "$tmp" --profile "$profile" "$vpn"; then result=0; else result=$?; fi
  else
    if bash "$tmp" --profile "$profile"; then result=0; else result=$?; fi
  fi
  rm -f "$tmp"
  return "$result"
}
setup_target(){
  local target="" local_mode=0 vpn="" row h u p j profile remote forward; local -a args=()
  while (($#)); do case "$1" in --local) local_mode=1;; --vpn) vpn=--vpn;; *) [[ -z "$target" ]] || die 'One target only'; target="$1";; esac; shift; done
  if ((local_mode)); then [[ -n "$target" ]] || die 'Local setup requires an alias: toxy setup --local <alias>'; run_local_setup "$target" "$vpn"; return; fi
  [[ -n "$target" ]] || target=$(choose)
  profile=base
  row=$(machine_row "$target")
  if [[ -n "$row" ]]; then
    IFS=$'\t' read -r _ h u p j profile remote forward <<< "$row"
    [[ "$remote" == 1 ]] || die "Machine $target has no SSH endpoint; use --local"
    args=(-p "$p"); [[ "$j" == - ]] || args+=(-J "$j"); target="$u@$h"
    [[ "$forward" == 0 ]] || args+=(-A)
  fi
  args+=(-o "SetEnv=TERM=$REMOTE_TERM")
  ssh "${args[@]}" -t "$target" "tmp=\$(mktemp) && trap 'rm -f \"\$tmp\"' EXIT && curl -fsSL '$SERVER_URL' -o \"\$tmp\" && bash \"\$tmp\" --profile '$profile' $vpn"
}
case "${1:-help}" in
  help|-h|--help) help_text;;
  machines) case "${2:-list}" in sync) machines_sync;; list) machines_list;; connect) [[ -n "${3:-}" ]] || die 'Alias required'; connect_machine "$3";; *) die 'Use sync, list or connect';; esac;;
  setup) shift; setup_target "$@";;
  *) help_text >&2; exit 1;;
esac
